{
  "name": "@graphlet/core",
  "version": "0.1.2",
  "description": "Tiny headless graph runtime",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "graph",
    "flow",
    "state-machine",
    "headless"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "homepage": "https://sicparv1smagna.github.io/graphlet/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sicparv1smagna/graphlet.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/sicparv1smagna/graphlet/issues"
  }
}
