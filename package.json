{
  "name": "graphlet",
  "version": "0.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "docs",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run docs:dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "core:build": "npm run build -w @graphlet/core",
    "core:typecheck": "npm run typecheck -w @graphlet/core",
    "core:test": "npm run test -w @graphlet/core",
    "react:build": "npm run build -w @graphlet/react",
    "react:typecheck": "npm run typecheck -w @graphlet/react",
    "react:clean": "npm run clean -w @graphlet/react",
    "docs:dev": "npm run dev -w @graphlet/docs",
    "docs:build": "npm run build -w @graphlet/docs",
    "docs:preview": "npm run preview -w @graphlet/docs",
    "example:react": "npm run dev -w @graphlet/example-react-basic",
    "example:react:build": "npm run build -w @graphlet/example-react-basic",
    "example:react:preview": "npm run preview -w @graphlet/example-react-basic"
  },
  "overrides": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SicParv1sMagna/graphlet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SicParv1sMagna/graphlet/issues"
  },
  "homepage": "https://github.com/SicParv1sMagna/graphlet#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
